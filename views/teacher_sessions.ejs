<!DOCTYPE html>
<html lang='en'>
<head>
    <meta charset='UTF-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <title>Browse Sessions - TutorLink Teacher</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel='stylesheet' href='/css/app.css'>
</head>
<body class='dashboard-page bg-light'>
    <nav class='nav shell' style='display:flex; justify-content:space-between; align-items:center; padding: 1rem 2rem; background:white; border-bottom:1px solid #eaeaea;'>
        <a class='brand' href='/' style='text-decoration:none; font-weight:bold; color:black;'><span class='brand-mark' style='background:black; color:white; padding:2px 6px; margin-right:5px; border-radius:4px;'>T</span>TutorLink</a>
        <div class='user-nav' style='display:flex; gap:1rem; align-items:center;'>
            <a href="/teacher" class="btn btn-outline-secondary btn-sm">Dashboard</a>
            <a href="/teacher/my-applications" class="btn btn-outline-primary btn-sm">My Applications</a>
            <b class='role-pill teacher-pill' style='background:#cff4fc; color:#055160; padding:4px 8px; border-radius:12px; font-size:0.8rem;'>Teacher</b>
            <span><strong><%= user.username %></strong></span>
            <a class='btn btn-danger btn-sm' href='/logout'>Log out</a>
        </div>
    </nav>
    <main class='dashboard shell container mt-4'>
        <% if (errorMessages.length) { %><div class='alert alert-danger'><%= errorMessages.join(' ') %></div><% } %>
        <% if (successMessages.length) { %><div class='alert alert-success'><%= successMessages.join(' ') %></div><% } %>
        
        <div class="mb-4">
            <h2>Available Sessions to Teach</h2>
            <p class="text-muted">Apply for sessions where you can share your expertise.</p>
        </div>

        <div class="row">
            <% if (sessions.length === 0) { %>
                <div class="col-12"><div class="alert alert-info">No sessions available right now.</div></div>
            <% } else { %>
                <% sessions.forEach(function(session) { %>
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title fw-bold text-primary"><%= session.subject %></h5>
                                <h6 class="card-subtitle mb-3 text-muted">
                                    <i class="bi bi-calendar"></i> <%= new Date(session.session_date).toLocaleDateString() %> at <%= session.session_time %>
                                </h6>
                                <p class="card-text mb-1"><strong>Location:</strong> <%= session.location %></p>
                                <p class="card-text mb-3"><strong>Capacity:</strong> <%= session.capacity %> students</p>
                                
                                <% if (session.my_status === 'approved') { %>
                                    <div class="alert alert-success p-2 mb-0 text-center">You are teaching this session!</div>
                                <% } else if (session.my_status === 'applied') { %>
                                    <div class="alert alert-warning p-2 mb-0 text-center">Application pending</div>
                                <% } else if (session.approved_teachers > 0) { %>
                                    <div class="alert alert-secondary p-2 mb-0 text-center">Assigned to another teacher</div>
                                <% } else { %>
                                    <form action="/teacher/sessions/<%= session.session_id %>/apply" method="POST">
                                        <button type="submit" class="btn btn-primary w-100">Apply to Teach</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </main>
</body>
</html>
