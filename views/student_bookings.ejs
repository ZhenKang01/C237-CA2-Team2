<!DOCTYPE html>
<html lang='en'>
<head>
    <meta charset='UTF-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <title>My Bookings - TutorLink Student</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel='stylesheet' href='/css/app.css'>
</head>
<body class='dashboard-page bg-light'>
    <nav class='nav shell' style='display:flex; justify-content:space-between; align-items:center; padding: 1rem 2rem; background:white; border-bottom:1px solid #eaeaea;'>
        <a class='brand' href='/' style='text-decoration:none; font-weight:bold; color:black;'><span class='brand-mark' style='background:black; color:white; padding:2px 6px; margin-right:5px; border-radius:4px;'>T</span>TutorLink</a>
        <div class='user-nav' style='display:flex; gap:1rem; align-items:center;'>
            <a href="/student" class="btn btn-outline-secondary btn-sm">Dashboard</a>
            <a href="/student/sessions" class="btn btn-outline-success btn-sm">Browse Sessions</a>
            <b class='role-pill student-pill' style='background:#d1e7dd; color:#0f5132; padding:4px 8px; border-radius:12px; font-size:0.8rem;'>Student</b>
            <span><strong><%= user.username %></strong></span>
            <a class='btn btn-danger btn-sm' href='/logout'>Log out</a>
        </div>
    </nav>
    <main class='dashboard shell container mt-4'>
        <% if (errorMessages.length) { %><div class='alert alert-danger'><%= errorMessages.join(' ') %></div><% } %>
        <% if (successMessages.length) { %><div class='alert alert-success'><%= successMessages.join(' ') %></div><% } %>
        
        <div class="mb-4">
            <h2>My Bookings</h2>
            <p class="text-muted">Keep track of your upcoming learning sessions.</p>
        </div>

        <div class="table-responsive bg-white rounded shadow-sm">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Subject</th>
                        <th>Location</th>
                        <th>Date & Time</th>
                        <th>Status</th>
                        <th>Booked On</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (bookings.length === 0) { %>
                        <tr><td colspan="6" class="text-center text-muted py-5">You haven't booked any sessions yet. <a href="/student/sessions">Browse Sessions</a></td></tr>
                    <% } else { %>
                        <% bookings.forEach(function(booking) { %>
                            <tr>
                                <td><strong><%= booking.subject %></strong></td>
                                <td><%= booking.location %></td>
                                <td>
                                    <%= new Date(booking.session_date).toLocaleDateString() %> <br>
                                    <small class="text-muted"><%= booking.session_time %></small>
                                </td>
                                <td>
                                    <% if (booking.status === 'booked') { %>
                                        <span class="badge bg-success px-2 py-1">Booked</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary px-2 py-1"><%= booking.status %></span>
                                    <% } %>
                                </td>
                                <td><small class="text-muted"><%= new Date(booking.booked_at).toLocaleDateString() %></small></td>
                                <td>
                                    <form action="/student/bookings/<%= booking.booking_id %>/optout" method="POST" onsubmit="return confirm('Are you sure you want to cancel your booking?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Opt Out</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>
