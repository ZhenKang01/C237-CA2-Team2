<!DOCTYPE html>
<html lang='en'>
<head>
    <meta charset='UTF-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <title><%= submitLabel %> - TutorLink Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel='stylesheet' href='/css/app.css'>
</head>
<body class='dashboard-page bg-light'>
    <nav class='nav shell' style='display:flex; justify-content:space-between; align-items:center; padding: 1rem 2rem; background:white; border-bottom:1px solid #eaeaea;'>
        <a class='brand' href='/' style='text-decoration:none; font-weight:bold; color:black;'><span class='brand-mark' style='background:black; color:white; padding:2px 6px; margin-right:5px; border-radius:4px;'>T</span>TutorLink</a>
        <div class='user-nav' style='display:flex; gap:1rem; align-items:center;'>
            <a href="/admin/sessions" class="btn btn-outline-secondary btn-sm">Back to Sessions</a>
            <a class='btn btn-danger btn-sm' href='/logout'>Log out</a>
        </div>
    </nav>
    <main class='dashboard shell container mt-5'>
        <% if (errorMessages.length) { %><div class='alert alert-danger'><%= errorMessages.join(' ') %></div><% } %>
        
        <div class="card shadow-sm mx-auto" style="max-width: 600px;">
            <div class="card-header bg-white pb-0 border-bottom-0 pt-4 px-4">
                <h2 class="h4 mb-0"><%= submitLabel %></h2>
            </div>
            <div class="card-body p-4">
                <form action="<%= formAction %>" method="POST">
                    <div class="mb-3">
                        <label for="subject" class="form-label fw-bold">Subject</label>
                        <input type="text" class="form-control" id="subject" name="subject" value="<%= session.subject || '' %>" required placeholder="e.g., Advanced Calculus">
                    </div>
                    
                    <div class="mb-3">
                        <label for="location" class="form-label fw-bold">Location</label>
                        <input type="text" class="form-control" id="location" name="location" value="<%= session.location || '' %>" required placeholder="e.g., Room 4B or Zoom Link">
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="session_date" class="form-label fw-bold">Date</label>
                            <% 
                                let dateVal = '';
                                if (session.session_date) {
                                    const d = new Date(session.session_date);
                                    dateVal = d.toISOString().split('T')[0];
                                }
                            %>
                            <input type="date" class="form-control" id="session_date" name="session_date" value="<%= dateVal %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="session_time" class="form-label fw-bold">Time</label>
                            <input type="time" class="form-control" id="session_time" name="session_time" value="<%= session.session_time || '' %>" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="capacity" class="form-label fw-bold">Student Capacity</label>
                        <input type="number" class="form-control" id="capacity" name="capacity" min="1" value="<%= session.capacity || 1 %>" required>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg"><%= submitLabel %></button>
                        <a href="/admin/sessions" class="btn btn-light">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
