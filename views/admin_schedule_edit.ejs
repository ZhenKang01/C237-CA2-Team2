<!DOCTYPE html>
<html lang='en'>
<head>
    <meta charset='UTF-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <title>Edit Schedule - TutorLink</title>
    <link rel='stylesheet' href='app.css'>
</head>
<body class='dashboard-page'>
    <% if (errorMessages && errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
    <header class='dashboard-header'>
        <div>
            <span class='eyebrow'>Admininstration</span>
            <h1>Edit Teaching Slot</h1>
            <p>Update the details of this slot.</p>
        </div>
        <div><a class='button secondary' href='/admin/schedules'>Back to Schedule</a></div>
    </header>

    <section class='panel' style='max-width:600px;'>
            <form action='/admin/schedules/<%= slot.slot_id %>/edit' method='POST' class='form'>
                <div class='form-group'>
                    <label>Teacher</label>
                    <select>
                        <% teachers.forEach(teacher => { %>
                            <option value='<%= teacher.teacher_id %>'><%= teacher.full_name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class='form-group'>
                    <label>Subject</label>
                    <input type='text' name='subject' class='input' value='<%= slot.subject %>' required>
                </div>
                <div class='form-group'>
                    <label>Location</label>
                    <input type='text' name='location' class='input' value='<%= slot.location %>' required>
                </div>
                <div class='form-group'>
                    <label>Date</label>
                    <input type='date' name='slot_date' class='input' value='<%= new Date(slot.slot_date).toISOString().split("T")[0] %>' required>
                </div>
                <div class='form-group'>
                    <label>Time</label>
                    <input type='time' name='slot_time' class='input' value='<%= slot.slot_time %>' required>
                </div>
                <button type='submit' class='button primary' style='width:100%'>Update Slot</button>
            </form>
        </section>
</body>
</html>